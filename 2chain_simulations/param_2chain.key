# System
BOX_SIZE           240 240 240

# Simulation settings
MC_TEMP            69.0
N_STEPS            2000000000
PREEQ_STEPS        0
PREEQ_TEMP         69.0
MC_TEMP_RATE       1.0
MC_TEMP_MODE       1 #Temperature protocol exponentially cools the system
MC_DELTA_TEMP      1
MC_INVERT_TEMP     0
MC_CYCLE_NUM       1
MC_UMBRELLA_SAMPLING_MODE 2 0 1 5.0 60

#Biasing potentials
MC_INDENT_MODE        0
BIAS_INDENT_RADIUS    50
BIAS_INDENT_STIFF     0.0
BIAS_COUPLED_TO_TEMP  1
BIAS_KEEP_ON          0

# MC move frequencies
MV_STROT_FREQ          0.0   # face change
MV_LOCAL_FREQ          3.0   # local move
MV_COLOCAL_FREQ        0.0   # co-local
MV_MTLOCAL_FREQ        1.0   # shake
MV_SNAKE_FREQ          0.0   # slithering snake
MV_TRANS_FREQ          1.0   # translation
MV_SMCLSTR_FREQ        0.0   # small cluster translation
MV_CLSTR_FREQ          0.0   # cluster translation
MV_PIVOT_FREQ          0.5   # pivot
MV_BRROT_FREQ          0.00 # branched rotate
MV_DBPVT_FREQ          0.0   # double pivot
MV_PR_SMCLSTR          0.00  # proximity clustering translation, small
MV_PR_CLSTR            0.00  # proximity cluster translation, second largest

STRUCT_FILETYPE 0  #0: Random Initial Conditions; 1: From restart file below.
STRUCT_FILE     ./WTARO_2_2_structure.prm
RESTART_FILE    restart_trj.lammpstrj #Can be a dummy name if not using.
ENERGY_FILE     ./energy_A1LCD.prm

RANDOM_SEED 967540493

# Report
REPORT_PREFIX         A1LCD
REPORT_LOG_FREQ       100000000
REPORT_ENERGY_FREQ    1000000
REPORT_CONFIG_FREQ    10000000
REPORT_MCMOVE_FREQ    100000000
REPORT_NETWORK_FREQ   0
REPORT_RDFTOT_FREQ    0
REPORT_COMDEN_FREQ    10000000
REPORT_UMBRELLA_FREQ  1000000

# Analyses
ANALYSIS_CLUSTER_MODE 2

# Modifiers
REPORT_CONFIG_MODE 1
